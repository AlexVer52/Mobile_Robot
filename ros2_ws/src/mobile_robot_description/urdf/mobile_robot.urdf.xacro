<robot name="mobile_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:property name="block_length" value="0.4"/>
    <xacro:property name="block_width" value="0.2"/>
    <xacro:property name="block_height" value="0.2"/>
    <xacro:property name="main_wheel_radius" value="0.08"/>
    <xacro:property name="main_wheel_width" value="0.04"/>
    <xacro:property name="center_wheel_radius" value="0.04"/>
    <xacro:property name="center_wheel_width" value="0.02"/>

    <link name="base_footprint"/>

    <link name="base_link">
      <visual>
        <geometry>
          <box size="${block_length} ${block_width} ${block_height}"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <box size="${block_length} ${block_width} ${block_height}"/>
        </geometry>
      </collision>
    </link>

    <xacro:macro name="wheel" params="name parent x y z wheel_radius wheel_width">
      <link name="${name}_wheel_link">
        <visual>
          <origin rpy="1.5708 0 0"/>
          <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
          </geometry>
        </visual>
        <collision>
          <origin rpy="1.5708 0 0"/>
          <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
          </geometry>
        </collision>
      </link>

      <joint name="${name}_wheel_joint" type="continuous">
        <parent link="${parent}"/>
        <child link="${name}_wheel_link"/>
        <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
      </joint>
    </xacro:macro>

    <joint name="base_footprint_joint" type="fixed">
      <parent link="base_footprint"/>
      <child link="base_link"/>
      <origin xyz="0 0 ${block_height/2 + center_wheel_radius}" rpy="0 0 0"/>
    </joint>

    <xacro:wheel name="left" parent="base_link" x="${block_length/4}" y="${block_width/2 + main_wheel_width/2}" z="${-block_height/2 + (main_wheel_radius-center_wheel_radius)}" wheel_radius="${main_wheel_radius}" wheel_width="${main_wheel_width}"/>
    <xacro:wheel name="right" parent="base_link" x="${block_length/4}" y="${-block_width/2 - main_wheel_width/2}" z="${-block_height/2 + (main_wheel_radius-center_wheel_radius)}" wheel_radius="${main_wheel_radius}" wheel_width="${main_wheel_width}"/>
    <xacro:wheel name="center" parent="base_link" x="-${block_length/4}" y="0" z="-${block_height/2}" wheel_radius="${center_wheel_radius}" wheel_width="${center_wheel_width}"/>
</robot>