<sdf version="1.10">
  <world name="simple_test">
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim8-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim8-imu-system" name="gz::sim::systems::Imu"/>

    <gravity>0 0 -9.81</gravity>

    <light name="sun" type="directional">
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>12 12</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>12 12</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.82 0.82 0.82 1</ambient>
            <diffuse>0.82 0.82 0.82 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="test_room_walls">
      <static>true</static>
      <link name="north_wall">
        <pose>0 3 0.5 0 0 0</pose>
        <collision name="collision"><geometry><box><size>6.0 0.12 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>6.0 0.12 1.0</size></box></geometry></visual>
      </link>
      <link name="south_wall">
        <pose>0 -3 0.5 0 0 0</pose>
        <collision name="collision"><geometry><box><size>6.0 0.12 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>6.0 0.12 1.0</size></box></geometry></visual>
      </link>
      <link name="east_wall">
        <pose>3 0 0.5 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.12 6.0 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.12 6.0 1.0</size></box></geometry></visual>
      </link>
      <link name="west_wall">
        <pose>-3 0 0.5 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.12 6.0 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.12 6.0 1.0</size></box></geometry></visual>
      </link>
    </model>
  </world>
</sdf>
